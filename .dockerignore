# Stuff the runtime doesn't need
.git/
.gitignore
.dockerignore
__pycache__/
*.pyc
.venv/
venv/

# Cloud Run serves /readings/<filename> directly so the 538 MB of PDFs go
# in the image. Netlify proxies /readings/* -> Cloud Run.
text_packs/
screenshots/
test_transcripts/
index.html
script.js
styles.css

# Source-of-truth + scripts -- not needed at runtime
*.md
filter_*.json
cluster_plan.json
surviving_questions.json
unit_corpus_state.json
preprocess.py
filter_and_cluster.py
build_clustered_corpus.py
run_tests.py
server.log
